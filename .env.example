APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# Auth marketing slider manifest (HandleInertiaRequests). Use CACHE_STORE=redis in production for shared cache.
# Bump AUTH_SLIDES_VERSION when replacing public/App/* slide assets so browsers fetch new files (query string + new Redis key).
AUTH_SLIDES_VERSION=3
AUTH_SLIDES_CACHE_TTL=86400

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Sanctum SPA auth — URL used for GET /sanctum/csrf-cookie
VITE_SANCTUM_URL=https://api.suganta.com

# --- API_Server (api.suganta.com) must be configured with: ---
# SANCTUM_STATEFUL_DOMAINS=app.suganta.com,localhost,localhost:3000
# SESSION_DOMAIN=.suganta.com
# SESSION_SAME_SITE=none
# SESSION_SECURE_COOKIE=true

# SuGanta API domain — single source of truth for all API base URLs
VITE_API_DOMAIN=https://api.suganta.com
# SuGanta API origin (must match axios allowlist in resources/js/api.js)
VITE_API_ORIGIN=https://api.suganta.com
VITE_API_TIMEOUT_MS=20000
VITE_GOOGLE_API_BASE_URL=${VITE_API_DOMAIN}/api/v4/google

# Laravel Reverb (Pusher protocol) — Echo websocket client; see docs/ChatApiV3Flutter.md §4.5
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=www.suganta.in
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# Laravel server: Firebase Admin SDK (FCM server-side). Never expose this file to the frontend.
FIREBASE_CREDENTIALS=storage/keys/suganta-tutors-firebase-adminsdk-fbsvc-51a7fa7774.json

# Firebase web (FCM browser) — Web API Key & App ID come from Firebase Console → Project settings → Your apps (Web).
# project_id matches the Admin SDK JSON (suganta-tutors); auth/storage defaults are typical for that project.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=suganta-tutors.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=suganta-tutors
VITE_FIREBASE_STORAGE_BUCKET=suganta-tutors.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_VAPID_KEY=
