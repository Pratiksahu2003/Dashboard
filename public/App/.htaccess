# Long-lived browser cache for auth marketing slider images (Apache).
# Nginx: use equivalent location ~* \.(png|jpe?g|webp)$ { add_header Cache-Control "public, max-age=31536000, immutable"; }
<IfModule mod_headers.c>
    <FilesMatch "\.(png|jpe?g|gif|webp|svg|avif)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>
